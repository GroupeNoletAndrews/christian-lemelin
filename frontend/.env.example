# ─────────────────────────────────────────────────────────────
# Frontend (Next.js) env. The app is a SINGLE deployment: the marketing site,
# /admin, and the API (route handlers under src/app/api) all run together.
#
# Local dev: copy DB URLs into `.env` (Prisma reads that) and the rest into
# `.env.local` (both are gitignored). On Vercel: set all of these in
# Project Settings → Environment Variables. Only NEXT_PUBLIC_* reach the browser.
# ─────────────────────────────────────────────────────────────

# ── Database: Supabase (Dashboard → Settings → Database → Connection string) ──
# DATABASE_URL = transaction pooler (port 6543, pgbouncer=true) — used at runtime.
# DIRECT_URL   = session/direct connection (port 5432) — used by migrate/seed.
# >>> Put these two in `.env` (NOT .env.local) so the Prisma CLI picks them up. <<<
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.YOUR_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ── Supabase Storage ──────────────────────────────────────────
# Client (browser) — publishable key (safe to expose).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Server (service-role / secret key) — for signed upload URLs + CV downloads.
# NEVER expose to the browser.
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxx

# ── Auth (admin JWT → httpOnly cookie) ────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Admin seed (run `npm run db:seed` once against the DB) ─────
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=replace-with-a-strong-password
# false in prod (no demo content; the admin user is still created).
SEED_DEMO_DATA=false

# ── Email notifications (Resend) ──────────────────────────────
# Both public forms (contact + job application) email a notification to MAIL_TO.
# Without RESEND_API_KEY, email is disabled (forms still succeed). Get a key at
# resend.com → API Keys.
RESEND_API_KEY=re_your_api_key
# Sender — MUST be "Name <email>". Dev: the shared onboarding@resend.dev (no
# domain to verify). Prod: an address on a domain you've VERIFIED in Resend.
MAIL_FROM=Entreprises Christian Lemelin <onboarding@resend.dev>
# Recipient. Dev: delivered@resend.dev (Resend test inbox — always "delivers",
# nothing to actually read). Prod: the real company inbox — currently
# et.arsenault2000@gmail.com (placeholder until a company address exists).
# ⚠️ With the shared onboarding@resend.dev sender (no verified domain), Resend
# only delivers to your OWN Resend account email — so in prod MAIL_TO must be
# that account's email until you verify a sending domain.
MAIL_TO=delivered@resend.dev
RESEND_WEBHOOK_SECRET=whsec_optional_signing_secret
