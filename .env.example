# docker-compose environment. Copy to .env (gitignored) and adjust as needed.
# All values have dev-safe defaults in docker-compose.yml, so .env is optional locally.

# --- Postgres (db service) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# --- Backend (NestJS + Prisma) ---
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=password

# --- Email notifications (Resend) ---
# Contact + job-application forms email the company via Resend (see README).
# Required to actually send; without it, sending is disabled (forms still work).
RESEND_API_KEY=re_your_api_key
# Dev defaults (in docker-compose.yml) use Resend test addresses so no domain
# verification is needed: MAIL_FROM=onboarding@resend.dev, MAIL_TO=delivered@resend.dev.
# Override here only if you want different addresses locally.
# MAIL_FROM=Entreprises Christian Lemelin <onboarding@resend.dev>
# MAIL_TO=delivered@resend.dev
# Optional: verify Resend webhook signatures (Resend dashboard → Webhooks → Signing Secret).
# RESEND_WEBHOOK_SECRET=whsec_...

# --- Frontend (Next.js) ---
# Baked into the client bundle at build time; the browser calls this URL.
NEXT_PUBLIC_API_URL=http://localhost:3001
