# docker-compose environment. Copy to .env (gitignored) and adjust as needed.
# All values have dev-safe defaults in docker-compose.yml, so .env is optional locally.

# --- Postgres (db service) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# --- Backend (NestJS + Prisma) ---
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=password

# --- Frontend (Next.js) ---
# Baked into the client bundle at build time; the browser calls this URL.
NEXT_PUBLIC_API_URL=http://localhost:3001
