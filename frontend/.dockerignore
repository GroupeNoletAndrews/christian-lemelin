# Frontend (Next.js) Docker build context = ./frontend.
# Exclude deps, build output, tests, docs and secrets from the image.
node_modules
.next
npm-debug.log*

# dotenv — values are passed via build args / runtime, never baked from files.
# (*.example are docs only and not needed in the image either.)
.env
.env.*

# Tests and their artifacts — not part of the production image.
e2e
playwright.config.ts
playwright-report
test-results
playwright/.cache

# Docs / docker meta
DESIGN.md
README.md
Dockerfile
.dockerignore
