# ─────────────────────────────────────────────────────────────
# Frontend (Next.js) env — copy to .env.local for `next dev`.
# Only NEXT_PUBLIC_* reach the browser. Never put real secrets here.
# ─────────────────────────────────────────────────────────────

# Public URL the browser uses to reach the backend API (baked into the build).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase (client + SSR)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ─── Optional / not yet wired on this branch ───
# Server-side Supabase service-role key (NEVER expose to the browser).
# SUPABASE_SECRET_KEY=sb_secret_xxx
# Sentry sourcemap upload, build-time (from the monitoring branch).
# SENTRY_AUTH_TOKEN=sntrys_xxx
