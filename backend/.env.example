# Backend (NestJS + Prisma) environment — copy to .env for local non-Docker runs.
# In docker-compose these are provided by the compose file.

# Postgres connection (Prisma reads DATABASE_URL). In compose this points at the
# `db` service. For Supabase prod, append ?sslmode=require to the URL.
DATABASE_URL=postgresql://app:app@localhost:5432/app

# Auth
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# HTTP
PORT=3001
CORS_ORIGIN=http://localhost:3000
# Dev only: also allow any http://localhost:<port> origin (e.g. `next dev`).
# Leave unset/false in production.
CORS_ALLOW_LOCALHOST=true

# Where uploaded CVs are written (mounted volume in compose)
UPLOADS_DIR=./uploads

# Max JSON body (réalisation images are data URLs) — keep generous.
JSON_BODY_LIMIT=25mb

# Seed admin credentials (used by dist/seed.js)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=password

# --- Email notifications (Resend) ---
# The contact + job-application forms send a notification email via Resend.
# RESEND_API_KEY is required to send; if unset, sending is disabled (the forms
# still save to the DB and return success). See README "Email notifications".
RESEND_API_KEY=re_your_api_key
# Sender. Dev: Resend's shared "onboarding@resend.dev" needs no domain verification.
# Prod: an address on YOUR verified domain (e.g. "Christian Lemelin <no-reply@eclemelin.com>").
MAIL_FROM=Entreprises Christian Lemelin <onboarding@resend.dev>
# Recipient (the company inbox). Dev: Resend test address that always "delivers".
# Prod: the real company address.
MAIL_TO=delivered@resend.dev
# Optional: Svix signing secret to verify Resend webhook calls (see /webhooks/resend).
RESEND_WEBHOOK_SECRET=

# ─── Monitoring — placeholder, not yet used on this branch ───
# Sentry → Discord relay (from the "baseline monitoring" branch). Uncomment + fill
# in when that feature is merged into this branch.
# DISCORD_MONITORING_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
# SENTRY_DISCORD_RELAY_SECRET=replace-with-relay-secret
