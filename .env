# ─────────────────────────────────────────────────────────────
# docker-compose ORCHESTRATION env (dev).  GITIGNORED.
# Auto-read by `docker compose` from the repo root.
#
# Backend app config (JWT, CORS, SEED, RESEND, MAIL…) now lives in backend/.env
# (loaded into the container via `env_file:` in docker-compose.yml), so this
# file only holds the truly orchestration-level values.
# ─────────────────────────────────────────────────────────────

# --- Postgres (db service + the DATABASE_URL the backend container is given) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# --- Frontend build arg (baked into the browser bundle at image build) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
