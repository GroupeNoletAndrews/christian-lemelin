// Prisma schema for Entreprises Christian Lemelin.
//
// Runs inside the Next.js app (Vercel). At runtime DATABASE_URL points at the
// Supabase transaction pooler (Supavisor, port 6543, ?pgbouncer=true&connection_limit=1);
// the Prisma CLI (migrate/seed) uses DIRECT_URL (direct/session connection, port 5432).
// In local dev both can point at the same local/Supabase Postgres.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model Job {
  id           String        @id @default(uuid()) @db.Uuid
  title        String
  description  String
  location     String
  // 'full-time' | 'part-time' | 'contract' — validated at the API layer.
  type         String
  department   String
  salary       String?
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  applications Application[]

  @@map("jobs")
}

model Realisation {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  images    String[]
  // Independent membership: `pinned` = shown on the home page (max N);
  // `inCollection` = shown on the /realisations page. A réalisation can be on
  // home only, in the collection only, both, or neither (draft).
  pinned    Boolean  @default(false)
  inCollection Boolean @default(true) @map("in_collection")
  // Admin-controlled display order (ascending). New réalisations append to the end.
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([pinned])
  @@index([inCollection])
  @@index([position])
  @@map("realisations")
}

// Generic key/value site settings (layout choices, etc.). Reusable across the
// app so a small config can persist without a bespoke table each time.
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("site_settings")
}

/// Published image override for a static-section slot (e.g. section "savoir-faire",
/// slot "mobilier"). Absence of a row means the slot uses its code default
/// (SITE_MEDIA key or seed→manifest). Drafts are staged client-side (nothing is
/// written here until publish), so there is no draft column — `key` is live.
model SectionImage {
  section   String
  slot      String
  key       String   @map("image_key")
  // Non-destructive per-slot presentation (all optional → backward-compatible).
  // The image still fills its fixed, layout-driven box; these only change WHICH
  // part of it shows (focal point + zoom) and its finish. Box SIZE never changes,
  // so responsiveness is preserved.
  objectPosition String?  @map("object_position") // focal point, e.g. "50% 30%"
  zoom           Float?   @map("zoom")             // scale within the box, 1 = 100%
  grayscale      Boolean? @map("is_grayscale")     // null = section's code default
  borderRadius   String?  @map("border_radius")    // e.g. "16px"
  border         String?  @map("border_style")     // e.g. "1px solid #cccccc"
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@id([section, slot])
  @@index([section])
  @@map("section_images")
}

model Application {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String?  @map("job_id") @db.Uuid
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  name      String
  email     String
  phone     String?
  message   String?
  // Supabase Storage object key for the uploaded CV (was a local disk path).
  cvPath    String?  @map("cv_path")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("applications")
}

model ContactMessage {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("contact_messages")
}
