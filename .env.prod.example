# Production env for docker-compose.prod.yml (Supabase is the database).
# Copy to .env.prod and fill in real values. NEVER commit real secrets.
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up --build -d

# --- Database: Supabase (Project Settings -> Database -> Connection string) ---
# Use the "Session"/direct connection for a long-running server, or the pooler
# (port 6543, ?pgbouncer=true) for serverless. Must include sslmode=require.
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- Public URLs ---
# Origin(s) of the deployed frontend, comma-separated (used for CORS, strict in prod).
CORS_ORIGIN=https://your-frontend-domain.com
# Public URL the browser uses to reach the backend API (baked into the frontend build).
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# --- Admin login (seeded into admin_users; demo content is NOT seeded in prod) ---
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=replace-with-a-strong-password
