# ─────────────────────────────────────────────────────────────
# docker-compose ORCHESTRATION env (dev). Copy to .env (gitignored).
# Dev-safe defaults already live in docker-compose.yml, so .env is optional.
#
# This file is ONLY the orchestration layer:
#   • POSTGRES_*          → the `db` service + the container's DATABASE_URL
#   • NEXT_PUBLIC_API_URL → the frontend image build arg
#
# Backend app config (JWT, CORS, SEED, RESEND, MAIL…) lives in backend/.env and
# is loaded into the backend container via `env_file:` — see backend/.env.example.
# Frontend dev vars (NEXT_PUBLIC_*) live in frontend/.env.example.
# ─────────────────────────────────────────────────────────────

# --- Postgres (db service) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# --- Frontend build arg (the browser calls this URL) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
