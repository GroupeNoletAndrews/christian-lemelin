# ─────────────────────────────────────────────────────────────
# Backend (NestJS + Prisma) — LOCAL NON-DOCKER env.  GITIGNORED.
# Copy from .env.example. Used by `npm run start:dev` outside Docker.
# In docker-compose these values come from the compose file (which reads
# the repo-root .env), so this file is only needed for the host-run backend.
# ─────────────────────────────────────────────────────────────

# Postgres connection (Prisma reads DATABASE_URL). In compose this points at the
# `db` service. For Supabase prod, append ?sslmode=require to the URL.
DATABASE_URL=postgresql://app:app@localhost:5432/app

# Auth
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# HTTP
PORT=3001
CORS_ORIGIN=http://localhost:3000
# Dev only: also allow any http://localhost:<port> origin (e.g. `next dev`).
# Leave unset/false in production.
CORS_ALLOW_LOCALHOST=true

# Where uploaded CVs are written (mounted volume in compose)
UPLOADS_DIR=./uploads

# Max JSON body (réalisation images are data URLs) — keep generous.
JSON_BODY_LIMIT=25mb

# Seed admin credentials (used by dist/seed.js)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=password

# --- Email notifications (Resend) ---
# The contact + job-application forms send a notification email via Resend.
# RESEND_API_KEY is required to send; if unset, sending is disabled (the forms
# still save to the DB and return success). See README "Email notifications".
RESEND_API_KEY=re_your_api_key
# Sender. Dev: Resend's shared "onboarding@resend.dev" needs no domain verification.
# Prod: an address on YOUR verified domain (e.g. "Christian Lemelin <no-reply@eclemelin.com>").
MAIL_FROM=Entreprises Christian Lemelin <onboarding@resend.dev>
# Recipient (the company inbox). Dev: Resend test address that always "delivers".
# Prod: the real company address.
MAIL_TO=delivered@resend.dev
# Optional: Svix signing secret to verify Resend webhook calls (see /webhooks/resend).
RESEND_WEBHOOK_SECRET=

# ─── Monitoring — NOT yet used on this branch (kept, commented) ───
# Sentry → Discord alert relay. These belong to the "baseline monitoring" branch;
# no code on feat/backend reads them yet. Uncomment when that feature lands here.
# (Relocated from the old root/.env and backend/.env top block during the
#  frontend/backend split — values preserved verbatim.)
# DISCORD_MONITORING_WEBHOOK_URL="https://discord.com/api/webhooks/1516988992745115720/XeI8AbLTfG5zOHyzJj3yFnuY53_RyU2oaX2Sv6E0bbiAdVxvRWF8_c1m-2rCCX5TMfRw"
# SENTRY_DISCORD_RELAY_SECRET="4bcdad399dde132afaec86474d2cd64f7a892a5056e41130"
#
# NOTE: the old frontend .env also carried DATABASE_USERNAME / DATABASE_PASSWORD /
# DATABASE_HOST. Prisma only uses DATABASE_URL, so they were intentionally dropped.
